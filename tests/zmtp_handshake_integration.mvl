// ── Test: REQ/REP message exchange ──────────────────────────────────────────

partial fn test_message() -> Unit ! Net + Console {
    let listener: TcpListener = match bind_ephemeral() {
        Err(_) => { println("message FAIL: listen error"); return },
        Ok(l)  => l,
    };
    let port: Int = match get_port(listener) {
        Err(_) => { tcp_close_listener(listener); println("message FAIL: port error"); return },
        Ok(p)  => p,
    };
    let c: MessageClient = actor MessageClient { port: port };
    c.exchange();
    let stream: TcpStream = match tcp_accept(listener) {
        Err(_) => { tcp_close_listener(listener); println("message FAIL: accept error"); return },
        Ok(s)  => s,
    };
    match zmtp_handshake_server(stream, ZmtpSocketType::Rep) {
        Err(e) => {
            tcp_close_stream(stream);
            tcp_close_listener(listener);
            println("message FAIL: handshake ".concat(zmq_error_msg(e)))
        },
        Ok(_) => {
            match zmtp_recv_message(stream) {
                Err(e) => {
                    tcp_close_stream(stream);
                    tcp_close_listener(listener);
                    println("message FAIL: recv ".concat(zmq_error_msg(e)))
                },
                Ok(msg) => {
                    let plain: String = relabel trust(msg, "TEST-RECV");
                    let _: Result[Unit, ZmqError] = zmtp_send_message(stream, "pong");
                    tcp_close_stream(stream);
                    tcp_close_listener(listener);
                    if plain == "ping" {
                        println("message ok")
                    } else {
                        println("message FAIL: expected ping, got ".concat(plain))
                    }
                },
            }
        },
    }
}

// ── Entry point ─────────────────────────────────────────────────────────────

partial fn main() -> Unit ! Net + Console {
    test_reqrep();
    test_pubsub();
    test_pushpull();
    test_message()
}
