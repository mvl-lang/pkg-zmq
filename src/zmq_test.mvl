// pkg.zmq tests — unit tests for wire framing and address parsing.
//
// All functions here are pure (no effects, no network).
//
// Non-pub helpers are re-declared locally (visibility constraint).
// Pub items could use imports — see #1061.
// Assurance note: 0 extern blocks.

use std.ifc.{Tainted}

// ── Type re-declarations ──────────────────────────────────────────────────────

type ZmqError = enum {
    NetError(String),
    FrameError(String),
    InvalidAddr(String),
}

type ZmqAddr = struct {
    host: String,
    port: Int,
}

// ── Helpers (mirror zmq.mvl logic for standalone testing) ─────────────────────

fn encode_frame(msg: String) -> String {
    let n: Int = msg.len();
    let b3: Byte = from_int(n.shift_right(24).bit_and(255));
    let b2: Byte = from_int(n.shift_right(16).bit_and(255));
    let b1: Byte = from_int(n.shift_right(8).bit_and(255));
    let b0: Byte = from_int(n.bit_and(255));
    String::from_bytes([b3, b2, b1, b0]).concat(msg)
}

fn decode_frame(raw: Tainted[String]) -> Result[Tainted[String], ZmqError] {
    let s: String = relabel trust(raw, "ZMQ-FRAME-PARSE");
    let slen: Int = s.len();
    if slen < 4 {
        Err(ZmqError::FrameError("frame too short"))
    } else {
        let b3: Int = s.byte_at(0).unwrap_or(from_int(0)).to_int();
        let b2: Int = s.byte_at(1).unwrap_or(from_int(0)).to_int();
        let b1: Int = s.byte_at(2).unwrap_or(from_int(0)).to_int();
        let b0: Int = s.byte_at(3).unwrap_or(from_int(0)).to_int();
        let expected_len: Int = b3.shift_left(24) + b2.shift_left(16) + b1.shift_left(8) + b0;
        if expected_len < 0 || expected_len > 67108864 {
            Err(ZmqError::FrameError("frame too large"))
        } else {
            let body_len: Int = slen - 4;
            if body_len != expected_len {
                Err(ZmqError::FrameError("length mismatch"))
            } else {
                let body: String = s.substring(4, slen);
                Ok(relabel taint(body, "ZMQ-RECV"))
            }
        }
    }
}

fn parse_zmq_addr(addr: String) -> Result[ZmqAddr, ZmqError] {
    let stripped: String = if addr.starts_with("tcp://") {
        addr.substring(6, addr.len())
    } else {
        addr
    };
    let s_len: Int = stripped.len();
    let resolved: String = if stripped.starts_with("*") {
        "0.0.0.0".concat(stripped.substring(1, s_len))
    } else {
        stripped
    };
    let res_len: Int = resolved.len();
    match resolved.find(":") {
        None    => Err(ZmqError::InvalidAddr("missing port separator")),
        Some(i) => {
            let host: String = resolved.substring(0, i);
            let port_str: String = resolved.substring(i + 1, res_len);
            if host.len() == 0 {
                Err(ZmqError::InvalidAddr("empty host"))
            } else {
                match port_str.parse_int() {
                    Err(_)   => Err(ZmqError::InvalidAddr("invalid port")),
                    Ok(port) => Ok(ZmqAddr { host: host, port: port }),
                }
            }
        },
    }
}

fn sub_topic(payload: Tainted[String]) -> String {
    let s: String = relabel trust(payload, "ZMQ-SUB-TOPIC");
    match s.find("\n") {
        None    => s,
        Some(i) => s.substring(0, i),
    }
}

fn sub_body(payload: Tainted[String]) -> Tainted[String] {
    let s: String = relabel trust(payload, "ZMQ-SUB-BODY");
    let slen: Int = s.len();
    let body: String = match s.find("\n") {
        None    => "",
        Some(i) => s.substring(i + 1, slen),
    };
    relabel taint(body, "ZMQ-SUB-BODY")
}

// ── encode_frame tests ────────────────────────────────────────────────────────

test fn encode_empty_message_is_4_bytes() -> Unit {
    let f: String = encode_frame("");
    assert_eq(f.len(), 4)
}

test fn encode_adds_length_to_body() -> Unit {
    let f: String = encode_frame("hi");
    assert_eq(f.len(), 6)
}

test fn encode_length_prefix_is_correct() -> Unit {
    let f: String = encode_frame("hello");
    let b3: Int = f.byte_at(0).unwrap_or(from_int(0)).to_int();
    let b2: Int = f.byte_at(1).unwrap_or(from_int(0)).to_int();
    let b1: Int = f.byte_at(2).unwrap_or(from_int(0)).to_int();
    let b0: Int = f.byte_at(3).unwrap_or(from_int(0)).to_int();
    let n: Int = b3.shift_left(24) + b2.shift_left(16) + b1.shift_left(8) + b0;
    assert_eq(n, 5)
}

test fn encode_body_appended_after_header() -> Unit {
    let f: String = encode_frame("abc");
    assert_eq(f.substring(4, f.len()), "abc")
}

test fn encode_high_bytes_are_zero_for_short_msg() -> Unit {
    let f: String = encode_frame("x");
    assert_eq(f.byte_at(0).unwrap_or(from_int(0)).to_int(), 0);
    assert_eq(f.byte_at(1).unwrap_or(from_int(0)).to_int(), 0);
    assert_eq(f.byte_at(2).unwrap_or(from_int(0)).to_int(), 0);
    assert_eq(f.byte_at(3).unwrap_or(from_int(0)).to_int(), 1)
}

// ── decode_frame tests ────────────────────────────────────────────────────────

test fn roundtrip_empty_string() -> Unit {
    match decode_frame(relabel taint(encode_frame(""), "TEST")) {
        Err(_) => assert_eq(true, false),
        Ok(s)  => assert_eq(relabel trust(s, "TEST"), ""),
    }
}

test fn roundtrip_short_message() -> Unit {
    match decode_frame(relabel taint(encode_frame("hi"), "TEST")) {
        Err(_) => assert_eq(true, false),
        Ok(s)  => assert_eq(relabel trust(s, "TEST"), "hi"),
    }
}

test fn roundtrip_longer_message() -> Unit {
    let msg: String = "the quick brown fox jumps over the lazy dog";
    match decode_frame(relabel taint(encode_frame(msg), "TEST")) {
        Err(_) => assert_eq(true, false),
        Ok(s)  => assert_eq(relabel trust(s, "TEST"), msg),
    }
}

test fn roundtrip_message_with_newline() -> Unit {
    let msg: String = "line1\nline2";
    match decode_frame(relabel taint(encode_frame(msg), "TEST")) {
        Err(_) => assert_eq(true, false),
        Ok(s)  => assert_eq(relabel trust(s, "TEST"), msg),
    }
}

test fn decode_too_short_is_frame_error() -> Unit {
    match decode_frame(relabel taint("abc", "TEST")) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn decode_empty_string_is_frame_error() -> Unit {
    match decode_frame(relabel taint("", "TEST")) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn decode_length_mismatch_is_frame_error() -> Unit {
    // Encode "hello" (5 bytes) then truncate body by 2 → length says 5, actual 3.
    let full: String = encode_frame("hello");
    let truncated: String = full.substring(0, 7);
    match decode_frame(relabel taint(truncated, "TEST")) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn decode_zero_length_frame_is_ok() -> Unit {
    let zero_frame: String = String::from_bytes([
        from_int(0), from_int(0), from_int(0), from_int(0)
    ]);
    match decode_frame(relabel taint(zero_frame, "TEST")) {
        Err(_) => assert_eq(true, false),
        Ok(s)  => assert_eq(relabel trust(s, "TEST"), ""),
    }
}

test fn decode_3_byte_frame_is_error() -> Unit {
    let short: String = String::from_bytes([from_int(0), from_int(0), from_int(0)]);
    match decode_frame(relabel taint(short, "TEST")) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn decode_frame_too_large_is_error() -> Unit {
    // Length header claims 0x7FFFFFFF bytes (> 64 MiB limit).
    let huge: String = String::from_bytes([from_int(127), from_int(255), from_int(255), from_int(255)]);
    match decode_frame(relabel taint(huge, "TEST")) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

// ── parse_zmq_addr tests ──────────────────────────────────────────────────────

test fn parse_bare_host_port() -> Unit {
    match parse_zmq_addr("localhost:5555") {
        Err(_) => assert_eq(true, false),
        Ok(a)  => {
            assert_eq(a.host, "localhost");
            assert_eq(a.port, 5555)
        },
    }
}

test fn parse_tcp_prefix_stripped() -> Unit {
    match parse_zmq_addr("tcp://localhost:5555") {
        Err(_) => assert_eq(true, false),
        Ok(a)  => {
            assert_eq(a.host, "localhost");
            assert_eq(a.port, 5555)
        },
    }
}

test fn parse_wildcard_star_becomes_any() -> Unit {
    match parse_zmq_addr("tcp://*:5555") {
        Err(_) => assert_eq(true, false),
        Ok(a)  => {
            assert_eq(a.host, "0.0.0.0");
            assert_eq(a.port, 5555)
        },
    }
}

test fn parse_ip_address() -> Unit {
    match parse_zmq_addr("192.168.1.100:9090") {
        Err(_) => assert_eq(true, false),
        Ok(a)  => {
            assert_eq(a.host, "192.168.1.100");
            assert_eq(a.port, 9090)
        },
    }
}

test fn parse_missing_port_is_invalid_addr() -> Unit {
    match parse_zmq_addr("localhost") {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::InvalidAddr(_) => assert_eq(true, true),
            _                        => assert_eq(true, false),
        },
    }
}

test fn parse_bad_port_is_invalid_addr() -> Unit {
    match parse_zmq_addr("localhost:xyz") {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::InvalidAddr(_) => assert_eq(true, true),
            _                        => assert_eq(true, false),
        },
    }
}

test fn parse_empty_host_is_invalid_addr() -> Unit {
    match parse_zmq_addr(":5555") {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::InvalidAddr(_) => assert_eq(true, true),
            _                        => assert_eq(true, false),
        },
    }
}

test fn parse_port_zero() -> Unit {
    match parse_zmq_addr("localhost:0") {
        Err(_) => assert_eq(true, false),
        Ok(a)  => assert_eq(a.port, 0),
    }
}

// ── PUB/SUB payload helpers ───────────────────────────────────────────────────

test fn sub_topic_extracts_prefix() -> Unit {
    assert_eq(sub_topic(relabel taint("news\nhello world", "TEST")), "news")
}

test fn sub_body_extracts_suffix() -> Unit {
    assert_eq(relabel trust(sub_body(relabel taint("news\nhello world", "TEST")), "TEST"), "hello world")
}

test fn sub_topic_no_newline_is_whole_string() -> Unit {
    assert_eq(sub_topic(relabel taint("no-newline", "TEST")), "no-newline")
}

test fn sub_body_no_newline_is_empty() -> Unit {
    assert_eq(relabel trust(sub_body(relabel taint("no-newline", "TEST")), "TEST"), "")
}

test fn sub_topic_empty_payload() -> Unit {
    assert_eq(sub_topic(relabel taint("", "TEST")), "")
}

test fn sub_roundtrip_topic_body() -> Unit {
    let topic: String = "alerts";
    let body: String = "server down";
    let payload: Tainted[String] = relabel taint(topic.concat("\n").concat(body), "TEST");
    assert_eq(sub_topic(payload), topic);
    assert_eq(relabel trust(sub_body(payload), "TEST"), body)
}

// ── ZMTP protocol helpers (re-declared from zmtp.mvl for standalone testing) ─

type ZmtpSocketType = enum {
    Req,
    Rep,
    Pub,
    Sub,
    Push,
    Pull,
}

fn socket_type_name(st: val ZmtpSocketType) -> String {
    match st {
        ZmtpSocketType::Req  => "REQ",
        ZmtpSocketType::Rep  => "REP",
        ZmtpSocketType::Pub  => "PUB",
        ZmtpSocketType::Sub  => "SUB",
        ZmtpSocketType::Push => "PUSH",
        ZmtpSocketType::Pull => "PULL",
    }
}

fn parse_socket_type(name: String) -> Result[ZmtpSocketType, ZmqError] {
    if name == "REQ" {
        Ok(ZmtpSocketType::Req)
    } else if name == "REP" {
        Ok(ZmtpSocketType::Rep)
    } else if name == "PUB" {
        Ok(ZmtpSocketType::Pub)
    } else if name == "SUB" {
        Ok(ZmtpSocketType::Sub)
    } else if name == "PUSH" {
        Ok(ZmtpSocketType::Push)
    } else if name == "PULL" {
        Ok(ZmtpSocketType::Pull)
    } else {
        Err(ZmqError::FrameError("unknown socket type: ".concat(name)))
    }
}

fn bval(n: Int) -> String {
    String::from_bytes([from_int(n.bit_and(255))])
}

fn zeros_8() -> String {
    String::from_bytes([from_int(0), from_int(0), from_int(0), from_int(0),
                        from_int(0), from_int(0), from_int(0), from_int(0)])
}

fn zeros_16() -> String { zeros_8().concat(zeros_8()) }
fn zeros_15() -> String {
    String::from_bytes([from_int(0), from_int(0), from_int(0), from_int(0),
                        from_int(0), from_int(0), from_int(0), from_int(0),
                        from_int(0), from_int(0), from_int(0), from_int(0),
                        from_int(0), from_int(0), from_int(0)])
}
fn zeros_31() -> String { zeros_16().concat(zeros_15()) }

fn make_greeting(as_server: Bool) -> String {
    let sig: String = bval(255).concat(zeros_8()).concat(bval(127));
    let ver: String = bval(3).concat(bval(1));
    let mech: String = "NULL".concat(zeros_16());
    let as_srv: String = if as_server { bval(1) } else { bval(0) };
    sig.concat(ver).concat(mech).concat(as_srv).concat(zeros_31())
}

fn validate_greeting(g: String) -> Result[Unit, ZmqError] {
    if g.len() != 64 {
        Err(ZmqError::FrameError("greeting not 64 bytes"))
    } else if g.byte_at(0).unwrap_or(from_int(0)).to_int() != 255 {
        Err(ZmqError::FrameError("bad signature byte 0"))
    } else if g.byte_at(9).unwrap_or(from_int(0)).to_int() != 127 {
        Err(ZmqError::FrameError("bad signature byte 9"))
    } else if g.byte_at(10).unwrap_or(from_int(0)).to_int() < 3 {
        Err(ZmqError::FrameError("ZMTP version < 3.x"))
    } else if g.substring(12, 16) != "NULL" {
        Err(ZmqError::FrameError("mechanism not NULL"))
    } else {
        Ok(())
    }
}

fn make_ready_body(st: ZmtpSocketType) -> String {
    let name: String = "READY";
    let name_len: String = bval(5);
    let key: String = "Socket-Type";
    let key_len: String = bval(11);
    let stype: String = socket_type_name(st);
    let stype_len: Int = stype.len();
    let stype_len_be: String = bval(0).concat(bval(0))
        .concat(bval(stype_len.shift_right(8).bit_and(255)))
        .concat(bval(stype_len.bit_and(255)));
    name_len.concat(name).concat(key_len).concat(key).concat(stype_len_be).concat(stype)
}

fn is_ping(body: String) -> Bool {
    if body.len() >= 5 {
        if body.byte_at(0).unwrap_or(from_int(0)).to_int() == 4 {
            body.substring(1, 5) == "PING"
        } else {
            false
        }
    } else {
        false
    }
}

fn ping_context(body: String) -> String {
    let blen: Int = body.len();
    if blen > 7 {
        body.substring(7, blen)
    } else {
        ""
    }
}

fn topic_passes_filter(plain: String, filter: String) -> Bool {
    if filter.len() == 0 {
        true
    } else {
        let topic: String = match plain.find("\n") {
            None    => plain.substring(0, plain.len()),
            Some(i) => plain.substring(0, i),
        };
        topic.starts_with(filter)
    }
}

fn parse_ready_body(body: String) -> Result[ZmtpSocketType, ZmqError] {
    let blen: Int = body.len();
    if blen < 6 {
        Err(ZmqError::FrameError("READY body too short"))
    } else {
        let name_len: Int = body.byte_at(0).unwrap_or(from_int(0)).to_int();
        if name_len != 5 {
            Err(ZmqError::FrameError("READY name length != 5"))
        } else {
            let name: String = body.substring(1, 6);
            if name != "READY" {
                Err(ZmqError::FrameError("expected READY command"))
            } else {
                parse_socket_type_property(body, 6)
            }
        }
    }
}

fn parse_socket_type_property(body: String, offset: Int) -> Result[ZmtpSocketType, ZmqError] {
    let blen: Int = body.len();
    if offset >= blen {
        Err(ZmqError::FrameError("no Socket-Type in READY"))
    } else {
        let key_len: Int = body.byte_at(offset).unwrap_or(from_int(0)).to_int();
        let key_start: Int = offset + 1;
        let key_end: Int = key_start + key_len;
        if key_end + 4 > blen {
            Err(ZmqError::FrameError("truncated READY property"))
        } else {
            let key: String = body.substring(key_start, key_end);
            let vl_b1: Int = body.byte_at(key_end).unwrap_or(from_int(0)).to_int();
            let vl_b2: Int = body.byte_at(key_end + 1).unwrap_or(from_int(0)).to_int();
            let vl_b3: Int = body.byte_at(key_end + 2).unwrap_or(from_int(0)).to_int();
            let vl_b4: Int = body.byte_at(key_end + 3).unwrap_or(from_int(0)).to_int();
            let vl: Int = vl_b1.shift_left(24) + vl_b2.shift_left(16)
                + vl_b3.shift_left(8) + vl_b4;
            let vs: Int = key_end + 4;
            let ve: Int = vs + vl;
            if ve > blen {
                Err(ZmqError::FrameError("truncated READY property value"))
            } else {
                let prop_val: String = body.substring(vs, ve);
                if key == "Socket-Type" {
                    parse_socket_type(prop_val)
                } else {
                    parse_socket_type_property(body, ve)
                }
            }
        }
    }
}

fn zmq_error_msg(e: val ZmqError) -> String {
    match e {
        ZmqError::NetError(msg)    => "net: ".concat(msg),
        ZmqError::FrameError(msg)  => "frame: ".concat(msg),
        ZmqError::InvalidAddr(msg) => "addr: ".concat(msg),
    }
}

fn is_transient_accept_error(e: val NetError) -> Bool {
    match e {
        NetError::ConnectionReset => true,
        NetError::Timeout         => true,
        _                         => false,
    }
}

use std.net.{NetError}

// ── socket_type_name / parse_socket_type tests ──────────────────────────────

test fn socket_type_name_req() -> Unit { assert_eq(socket_type_name(ZmtpSocketType::Req), "REQ") }
test fn socket_type_name_rep() -> Unit { assert_eq(socket_type_name(ZmtpSocketType::Rep), "REP") }
test fn socket_type_name_pub() -> Unit { assert_eq(socket_type_name(ZmtpSocketType::Pub), "PUB") }
test fn socket_type_name_sub() -> Unit { assert_eq(socket_type_name(ZmtpSocketType::Sub), "SUB") }
test fn socket_type_name_push() -> Unit { assert_eq(socket_type_name(ZmtpSocketType::Push), "PUSH") }
test fn socket_type_name_pull() -> Unit { assert_eq(socket_type_name(ZmtpSocketType::Pull), "PULL") }

test fn parse_socket_type_req() -> Unit {
    assert_eq(parse_socket_type("REQ").is_ok(), true)
}
test fn parse_socket_type_rep() -> Unit {
    assert_eq(parse_socket_type("REP").is_ok(), true)
}
test fn parse_socket_type_pub() -> Unit {
    assert_eq(parse_socket_type("PUB").is_ok(), true)
}
test fn parse_socket_type_sub() -> Unit {
    assert_eq(parse_socket_type("SUB").is_ok(), true)
}
test fn parse_socket_type_push() -> Unit {
    assert_eq(parse_socket_type("PUSH").is_ok(), true)
}
test fn parse_socket_type_pull() -> Unit {
    assert_eq(parse_socket_type("PULL").is_ok(), true)
}
test fn parse_socket_type_unknown() -> Unit {
    assert_eq(parse_socket_type("DEALER").is_err(), true)
}

// ── greeting tests ──────────────────────────────────────────────────────────

test fn greeting_is_64_bytes() -> Unit {
    assert_eq(make_greeting(true).len(), 64);
    assert_eq(make_greeting(false).len(), 64)
}

test fn greeting_signature_bytes() -> Unit {
    let g: String = make_greeting(true);
    assert_eq(g.byte_at(0).unwrap_or(from_int(0)).to_int(), 255);
    assert_eq(g.byte_at(9).unwrap_or(from_int(0)).to_int(), 127)
}

test fn greeting_version_3_1() -> Unit {
    let g: String = make_greeting(true);
    assert_eq(g.byte_at(10).unwrap_or(from_int(0)).to_int(), 3);
    assert_eq(g.byte_at(11).unwrap_or(from_int(0)).to_int(), 1)
}

test fn greeting_mechanism_null() -> Unit {
    let g: String = make_greeting(true);
    assert_eq(g.substring(12, 16), "NULL")
}

test fn greeting_as_server_flag() -> Unit {
    assert_eq(make_greeting(true).byte_at(32).unwrap_or(from_int(0)).to_int(), 1);
    assert_eq(make_greeting(false).byte_at(32).unwrap_or(from_int(0)).to_int(), 0)
}

test fn validate_greeting_roundtrip_server() -> Unit {
    assert_eq(validate_greeting(make_greeting(true)).is_ok(), true)
}

test fn validate_greeting_roundtrip_client() -> Unit {
    assert_eq(validate_greeting(make_greeting(false)).is_ok(), true)
}

test fn validate_greeting_too_short() -> Unit {
    assert_eq(validate_greeting("short").is_err(), true)
}

test fn validate_greeting_bad_sig_byte_0() -> Unit {
    let g: String = bval(0).concat(make_greeting(true).substring(1, 64));
    assert_eq(validate_greeting(g).is_err(), true)
}

test fn validate_greeting_bad_sig_byte_9() -> Unit {
    let g: String = make_greeting(true).substring(0, 9).concat(bval(0)).concat(make_greeting(true).substring(10, 64));
    assert_eq(validate_greeting(g).is_err(), true)
}

test fn validate_greeting_old_version() -> Unit {
    let g: String = make_greeting(true).substring(0, 10).concat(bval(2)).concat(make_greeting(true).substring(11, 64));
    assert_eq(validate_greeting(g).is_err(), true)
}

test fn validate_greeting_bad_mechanism() -> Unit {
    let g: String = make_greeting(true).substring(0, 12).concat("PLAI").concat(make_greeting(true).substring(16, 64));
    assert_eq(validate_greeting(g).is_err(), true)
}

// ── READY body tests ────────────────────────────────────────────────────────

test fn ready_body_starts_with_ready() -> Unit {
    let body: String = make_ready_body(ZmtpSocketType::Rep);
    assert_eq(body.byte_at(0).unwrap_or(from_int(0)).to_int(), 5);
    assert_eq(body.substring(1, 6), "READY")
}

test fn ready_body_contains_socket_type() -> Unit {
    let body: String = make_ready_body(ZmtpSocketType::Req);
    let blen: Int = body.len();
    assert_eq(body.substring(blen - 3, blen), "REQ")
}

// ── PING/PONG tests ────────────────────────────────────────────────────────

test fn is_ping_valid() -> Unit {
    let body: String = bval(4).concat("PING").concat(bval(0)).concat(bval(30));
    assert_eq(is_ping(body), true)
}

test fn is_ping_wrong_name_len() -> Unit {
    let body: String = bval(3).concat("PIN").concat(bval(0)).concat(bval(0));
    assert_eq(is_ping(body), false)
}

test fn is_ping_wrong_name() -> Unit {
    let body: String = bval(4).concat("PONG");
    assert_eq(is_ping(body), false)
}

test fn is_ping_too_short() -> Unit {
    assert_eq(is_ping("hi"), false)
}

test fn ping_context_with_data() -> Unit {
    let body: String = bval(4).concat("PING").concat(bval(0)).concat(bval(30)).concat("ctx");
    assert_eq(ping_context(body), "ctx")
}

test fn ping_context_empty() -> Unit {
    let body: String = bval(4).concat("PING").concat(bval(0)).concat(bval(0));
    assert_eq(ping_context(body), "")
}

test fn ping_context_short_body() -> Unit {
    assert_eq(ping_context("short"), "")
}

// ── topic_passes_filter tests ───────────────────────────────────────────────

test fn filter_empty_matches_all() -> Unit {
    assert_eq(topic_passes_filter("weather\nNYC 72F", ""), true)
}

test fn filter_matching_prefix() -> Unit {
    assert_eq(topic_passes_filter("weather\nNYC 72F", "wea"), true)
}

test fn filter_non_matching() -> Unit {
    assert_eq(topic_passes_filter("weather\nNYC 72F", "sports"), false)
}

test fn filter_exact_topic() -> Unit {
    assert_eq(topic_passes_filter("weather\nNYC 72F", "weather"), true)
}

test fn filter_no_newline() -> Unit {
    assert_eq(topic_passes_filter("weather", "weather"), true)
}

// ── is_transient_accept_error tests ─────────────────────────────────────────

test fn transient_connection_reset() -> Unit {
    assert_eq(is_transient_accept_error(NetError::ConnectionReset), true)
}

test fn transient_timeout() -> Unit {
    assert_eq(is_transient_accept_error(NetError::Timeout), true)
}

test fn not_transient_other() -> Unit {
    assert_eq(is_transient_accept_error(NetError::ConnectionRefused), false)
}

// ── parse_ready_body roundtrip tests ─────────────────────────────────────────

test fn ready_roundtrip_req() -> Unit {
    match parse_ready_body(make_ready_body(ZmtpSocketType::Req)) {
        Err(_) => assert_eq(true, false),
        Ok(st) => assert_eq(socket_type_name(st), "REQ"),
    }
}

test fn ready_roundtrip_rep() -> Unit {
    match parse_ready_body(make_ready_body(ZmtpSocketType::Rep)) {
        Err(_) => assert_eq(true, false),
        Ok(st) => assert_eq(socket_type_name(st), "REP"),
    }
}

test fn ready_roundtrip_pub() -> Unit {
    match parse_ready_body(make_ready_body(ZmtpSocketType::Pub)) {
        Err(_) => assert_eq(true, false),
        Ok(st) => assert_eq(socket_type_name(st), "PUB"),
    }
}

test fn ready_roundtrip_sub() -> Unit {
    match parse_ready_body(make_ready_body(ZmtpSocketType::Sub)) {
        Err(_) => assert_eq(true, false),
        Ok(st) => assert_eq(socket_type_name(st), "SUB"),
    }
}

test fn ready_roundtrip_push() -> Unit {
    match parse_ready_body(make_ready_body(ZmtpSocketType::Push)) {
        Err(_) => assert_eq(true, false),
        Ok(st) => assert_eq(socket_type_name(st), "PUSH"),
    }
}

test fn ready_roundtrip_pull() -> Unit {
    match parse_ready_body(make_ready_body(ZmtpSocketType::Pull)) {
        Err(_) => assert_eq(true, false),
        Ok(st) => assert_eq(socket_type_name(st), "PULL"),
    }
}

// ── parse_ready_body error tests ────────────────────────────────────────────

test fn ready_body_too_short() -> Unit {
    match parse_ready_body("short") {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn ready_body_empty() -> Unit {
    match parse_ready_body("") {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn ready_body_bad_name_length() -> Unit {
    // name_len=3 instead of 5, followed by "REA" + padding
    let body: String = bval(3).concat("READY_extra_padding");
    match parse_ready_body(body) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn ready_body_wrong_name() -> Unit {
    // name_len=5 but name="HELLO" instead of "READY"
    let body: String = bval(5).concat("HELLO").concat(bval(11)).concat("Socket-Type")
        .concat(bval(0)).concat(bval(0)).concat(bval(0)).concat(bval(3)).concat("REQ");
    match parse_ready_body(body) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

// ── parse_socket_type_property error tests ──────────────────────────────────

test fn socket_type_property_no_property() -> Unit {
    // Valid READY header but offset at end of body — no properties
    let body: String = bval(5).concat("READY");
    match parse_socket_type_property(body, 6) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn socket_type_property_truncated_header() -> Unit {
    // Key length says 20 but body ends before key_end + 4
    let body: String = bval(5).concat("READY").concat(bval(20)).concat("short");
    match parse_socket_type_property(body, 6) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn socket_type_property_truncated_value() -> Unit {
    // Valid key header but value length exceeds body
    let body: String = bval(5).concat("READY")
        .concat(bval(11)).concat("Socket-Type")
        .concat(bval(0)).concat(bval(0)).concat(bval(0)).concat(bval(99));
    match parse_socket_type_property(body, 6) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

test fn socket_type_property_skips_unknown_key() -> Unit {
    // First property: "Identity" = "test", then Socket-Type = "REP"
    let body: String = bval(5).concat("READY")
        .concat(bval(8)).concat("Identity")
        .concat(bval(0)).concat(bval(0)).concat(bval(0)).concat(bval(4)).concat("test")
        .concat(bval(11)).concat("Socket-Type")
        .concat(bval(0)).concat(bval(0)).concat(bval(0)).concat(bval(3)).concat("REP");
    match parse_ready_body(body) {
        Err(_) => assert_eq(true, false),
        Ok(st) => assert_eq(socket_type_name(st), "REP"),
    }
}

test fn socket_type_property_unknown_type_value() -> Unit {
    // Socket-Type = "DEALER" — valid property but unknown socket type
    let body: String = bval(5).concat("READY")
        .concat(bval(11)).concat("Socket-Type")
        .concat(bval(0)).concat(bval(0)).concat(bval(0)).concat(bval(6)).concat("DEALER");
    match parse_ready_body(body) {
        Ok(_)  => assert_eq(true, false),
        Err(e) => match e {
            ZmqError::FrameError(_) => assert_eq(true, true),
            _                       => assert_eq(true, false),
        },
    }
}

// ── zmq_error_msg tests ─────────────────────────────────────────────────────

test fn error_msg_net() -> Unit {
    assert_eq(zmq_error_msg(ZmqError::NetError("timeout")), "net: timeout")
}

test fn error_msg_frame() -> Unit {
    assert_eq(zmq_error_msg(ZmqError::FrameError("too short")), "frame: too short")
}

test fn error_msg_addr() -> Unit {
    assert_eq(zmq_error_msg(ZmqError::InvalidAddr("bad port")), "addr: bad port")
}

// ── Property-based tests ────────────────────────────────────────────────────

use std.pbt.{gen_string, property_check_string}

test fn pbt_encode_decode_roundtrip() -> Unit ! Random {
    property_check_string(
        "encode/decode roundtrip", gen_string(0, 100),
        |s: String| -> Bool {
            match decode_frame(relabel taint(encode_frame(s), "TEST")) {
                Err(_) => false,
                Ok(decoded) => relabel trust(decoded, "TEST") == s,
            }
        },
        200
    )
}

test fn pbt_encode_length_is_input_plus_4() -> Unit ! Random {
    property_check_string(
        "encode length == input + 4", gen_string(0, 100),
        |s: String| -> Bool { encode_frame(s).len() == s.len() + 4 },
        200
    )
}

test fn pbt_sub_topic_body_roundtrip() -> Unit ! Random {
    property_check_string(
        "sub_topic/sub_body roundtrip", gen_string(1, 50),
        |topic: String| -> Bool {
            let payload: Tainted[String] = relabel taint(topic.concat("\n").concat("test-body"), "TEST");
            sub_topic(payload) == topic && relabel trust(sub_body(payload), "TEST") == "test-body"
        },
        200
    )
}
